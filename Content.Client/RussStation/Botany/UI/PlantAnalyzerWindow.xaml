<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    MinWidth="360"
    MaxHeight="560">
    <BoxContainer Orientation="Vertical">
        <Label Name="PlantNameLabel"
               HorizontalAlignment="Center"
               Margin="4 4 4 2"
               StyleClasses="LabelHeading" />
        <PanelContainer StyleClasses="LowDivider" />
        <TabContainer Name="Tabs">
            <ScrollContainer Name="StatsTab" Margin="5 5 5 5" ReturnMeasure="True" VerticalExpand="True">
                <BoxContainer Name="StatsBox" Orientation="Vertical" SeparationOverride="4" />
            </ScrollContainer>
            <ScrollContainer Name="TraitsTab" Margin="5 5 5 5" ReturnMeasure="True" VerticalExpand="True">
                <BoxContainer Name="TraitsBox" Orientation="Vertical" SeparationOverride="4" />
            </ScrollContainer>
            <ScrollContainer Name="ChemicalsTab" Margin="5 5 5 5" ReturnMeasure="True" VerticalExpand="True">
                <BoxContainer Name="ChemicalsBox" Orientation="Vertical" SeparationOverride="4" />
            </ScrollContainer>
        </TabContainer>
    </BoxContainer>
</controls:FancyWindow>
